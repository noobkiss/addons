<GuiXml xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sir.insidi.at/or/schema/esoui.xsd">
    <Controls>
        <Control name="sidItemListRow" mouseEnabled="true" virtual="true">
            <Dimensions y="30" />
            <OnMouseEnter>
                sidTools.ItemListRow_OnMouseEnter(self)
            </OnMouseEnter>
            <OnMouseExit>
                sidTools.ItemListRow_OnMouseExit(self)
            </OnMouseExit>
            <OnMouseUp>
                sidTools.ItemListRow_OnMouseUp(self, button, upInside)
            </OnMouseUp>
            <Controls>
                <Texture name="$(parent)BG" inherits="ZO_ThinListBgStrip" />
                <Label name="$(parent)ItemID" inherits="ZO_FriendsListRowLabel">
                    <Anchor point="LEFT" />
                    <Dimensions x="50" y="30" />
                </Label>
                <Label name="$(parent)ItemName" inherits="ZO_FriendsListRowLabel">
                    <Anchor point="LEFT" relativePoint="RIGHT" relativeTo="$(parent)ItemID" offsetX="18" />
                    <Dimensions x="200" y="30" />
                </Label>
                <Label name="$(parent)ItemType" inherits="ZO_FriendsListRowLabel">
                    <Anchor point="LEFT" relativePoint="RIGHT" relativeTo="$(parent)ItemName" offsetX="38" />
                    <Dimensions x="100" y="30" />
                </Label>
            </Controls>
        </Control>

        <Backdrop name="sidItemListSearch" tier="HIGH" inherits="ZO_EditBackdrop" virtual="true">
            <Dimensions x="250" />
            <Controls>
                <EditBox name="$(parent)Box" inherits="ZO_DefaultEditForBackdrop ZO_EditDefaultText">
                </EditBox>
            </Controls>
        </Backdrop>

        <Control name="sidItemListScanRange" resizeToFitDescendents="true" virtual="true">
            <Controls>
                <Label name="$(parent)Label" font="ZoFontWinT1" color="ZO_WHITE" text="Id Range:">
                    <Anchor point="LEFT" />
                </Label>
                <Backdrop name="$(parent)FromId" inherits="sidItemListSearch">
                    <Anchor point="LEFT" relativePoint="RIGHT" relativeTo="$(parent)Label" offsetX="10" />
                    <Dimensions x="70" />
                </Backdrop>
                <Label name="$(parent)Separator" font="ZoFontWinT1" color="ZO_WHITE" text="-">
                    <Anchor point="LEFT" relativePoint="RIGHT" relativeTo="$(parent)FromId" offsetX="10" />
                </Label>
                <Backdrop name="$(parent)ToId" inherits="sidItemListSearch">
                    <Anchor point="LEFT" relativePoint="RIGHT" relativeTo="$(parent)Separator" offsetX="10" />
                    <Dimensions x="70" />
                </Backdrop>
                <Button name="$(parent)Button" text="Start Scan" inherits="ZO_DefaultTextButton">
                    <Anchor point="LEFT" relativePoint="RIGHT" relativeTo="$(parent)ToId" offsetX="10" />
                    <Dimensions x="100" />
                </Button>
            </Controls>
        </Control>
    </Controls>
</GuiXml>