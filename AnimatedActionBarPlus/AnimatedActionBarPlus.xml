<GuiXml>
<Controls>

    <Control name="ALT_ActionBar1" virtual="true">
        <Controls>
            <Texture name="$(parent)KeybindBG" alpha="0" hidden="true" />
            <Button  name="$(parent)WeaponSwap" alpha="0" hidden="true" />
        </Controls>
    </Control>

    <Control name="ALT_ActionButton" virtual="true">
        <Dimensions x="50" y="50" />
        <Controls>
            <Control name="$(parent)FlipCard">
                <Dimensions x="47" y="47" />
            </Control>

            <Texture name="$(parent)Icon">
                <Dimensions x="47" y="47" />
            </Texture>

            <Texture name="$(parent)CooldownIcon" hidden="true" />

            <Button name="$(parent)Button" hidden="false" alpha="0" />

            <Label name="$(parent)ButtonText" font="ZoFontGamepad18">
                <Dimensions x="0" y="25" />
                <Anchor point="TOP" relativePoint="BOTTOM" offsetY="-6" />
            </Label>

            <Label name="$(parent)StackCountText" font="ZoFontGamepad27" color="DCD822">
                <Dimensions x="0" y="25" />
                <Anchor point="CENTER" relativePoint="CENTER" offsetX="23" offsetY="-20" />
            </Label>

            <Label name="$(parent)TimerText" font="ZoFontGamepad27" color="DCD822">
                <Dimensions x="0" y="25" />
                <Anchor point="CENTER" relativePoint="CENTER" offsetY="ACTION_BUTTON_TIMER_TEXT_OFFSET_Y_DEFAULT_GAMEPAD" />
            </Label>

            <Texture name="$(parent)TimerOverlay">
                <Dimensions x="47" y="47" />
            </Texture>

            <Texture name="$(parent)Glow" hidden="false" alpha="0" />
            <Texture name="$(parent)BG"   hidden="false" alpha="1" />

            <Backdrop name="$(parent)Backdrop" inherits="ZO_DefaultBackdrop" hidden="false" alpha="1">
                <Anchor point="TOPLEFT"     relativeTo="$(parent)FlipCard" offsetX="-4" offsetY="-4" />
                <Anchor point="BOTTOMRIGHT" relativeTo="$(parent)FlipCard" offsetX="4"  offsetY="4" />
                <Edge   file="AnimatedActionBarPlus/CustomEdge.dds"   edgeFileWidth="128" edgeFileHeight="16" />
                <Center file="AnimatedActionBarPlus/CustomCenter.dds" />
                <Controls>
                    <Texture name="$(parent)MungeOverlay" alpha="0" />
                </Controls>
            </Backdrop>
        </Controls>
    </Control>

    <Control name="ALT_ActionButton_V2" virtual="true">
        <Dimensions x="50" y="50" />
        <Controls>
            <Control name="$(parent)FlipCard">
                <Dimensions x="47" y="47" />
            </Control>

            <Texture name="$(parent)Icon">
                <Dimensions x="47" y="47" />
            </Texture>

            <Texture name="$(parent)CooldownIcon" hidden="true" />

            <Button name="$(parent)Button" hidden="false" alpha="0" />

            <Label name="$(parent)ButtonText" font="ZoFontGamepad18">
                <Dimensions x="0" y="25" />
                <Anchor point="TOP" relativePoint="BOTTOM" offsetY="-6" />
            </Label>

            <Label name="$(parent)StackCountText" font="ZoFontGamepad27" color="DCD822">
                <Dimensions x="0" y="25" />
                <Anchor point="CENTER" relativePoint="CENTER" offsetX="23" offsetY="-20" />
            </Label>

            <Label name="$(parent)TimerText" font="ZoFontGamepad27" color="DCD822">
                <Dimensions x="0" y="25" />
                <Anchor point="CENTER" relativePoint="CENTER" offsetY="ACTION_BUTTON_TIMER_TEXT_OFFSET_Y_DEFAULT_GAMEPAD" />
            </Label>

            <Texture name="$(parent)TimerOverlay">
                <Dimensions x="47" y="47" />
            </Texture>

            <Texture name="$(parent)Glow" hidden="false" alpha="0" />
            <Texture name="$(parent)BG"   hidden="false" alpha="1" />

            <Backdrop name="$(parent)Backdrop" inherits="ZO_DefaultBackdrop" hidden="false" alpha="1">
                <Anchor point="TOPLEFT"     relativeTo="$(parent)FlipCard" offsetX="-4" offsetY="-4" />
                <Anchor point="BOTTOMRIGHT" relativeTo="$(parent)FlipCard" offsetX="4"  offsetY="4" />
                <Edge   file="AnimatedActionBarPlus/CustomEdge2.dds"  edgeFileWidth="128" edgeFileHeight="16" />
                <Center file="AnimatedActionBarPlus/CustomCenter.dds" />
                <Controls>
                    <Texture name="$(parent)MungeOverlay" alpha="0" />
                </Controls>
            </Backdrop>
        </Controls>
    </Control>

    <Texture name="AABPlus_GlowTemplate" virtual="true"
             textureFile="EsoUI/Art/HUD/Gamepad/gp_skillGlow.dds"
             tier="HIGH" level="5" hidden="false" alpha="0">
        <TextureCoords left="0.1875" right="0.8125" top="0.1875" bottom="0.8125" />
    </Texture>

</Controls>
</GuiXml>
