<GuiXml>
    <Controls>
        <TopLevelControl name="BattlegroundCoffersWindow" mouseEnabled="true" movable="true">
            <Dimensions x="530" y="78"/>
            <Anchor point="CENTER" relativeTo="GuiRoot" relativePoint="CENTER" offsetX="0" offsetY="0" />

            <Controls>
                <Backdrop name="$(parent)BG" inherits="ZO_DefaultBackdrop" alpha="1"/>

                <Control name="$(parent)Header" resizeToFitDescendents="true">
                    <Dimensions y="54"/>
                    <Anchor point="TOPLEFT" relativeTo="$(parent)" relativePoint="TOPLEFT" offsetX="12" offsetY="6"/>
                    <Anchor point="TOPRIGHT" relativeTo="$(parent)" relativePoint="TOPRIGHT" offsetX="-12" offsetY="6"/>

                    <Controls>
                        <Label name="$(parent)Title" font="$(ANTIQUE_FONT)|18" text="Battleground Coffers &amp; Alliance Tier" horizontalAlignment="CENTER" verticalAlignment="CENTER">
                            <Dimensions y="24"/>
                            <Anchor point="TOPLEFT" relativeTo="$(parent)" relativePoint="TOPLEFT" offsetX="0" offsetY="0"/>
                            <Anchor point="TOPRIGHT" relativeTo="$(parent)" relativePoint="TOPRIGHT" offsetX="0" offsetY="0"/>
                        </Label>

                        <Button name="$(parent)Hide">
                            <Anchor point="TOPRIGHT" relativeTo="$(parent)" relativePoint="TOPRIGHT" offsetX="15" offsetY="-9"/>
                            <OnClicked>BattlegroundCoffers.toggleWindow()</OnClicked>
                            <Dimensions x="25" y="25" />
                            <Textures normal="/esoui/art/buttons/decline_up.dds" pressed="/esoui/art/buttons/decline_down.dds" mouseOver="/esoui/art/buttons/decline_over.dds" />
                        </Button>

                        <Label name="$(parent)HeaderName" font="$(ANTIQUE_FONT)|16" text="Character" horizontalAlignment="CENTER" verticalAlignment="BOTTOM">
                            <Dimensions x="210" y="24"/>
                            <Anchor point="TOPLEFT" relativeTo="$(parent)Title" relativePoint="BOTTOMLEFT" offsetX="-12" offsetY="0"/>
                        </Label>

                        <Label name="$(parent)HeaderBGCoffer" font="$(ANTIQUE_FONT)|16" wrapMode="ELLIPSIS" text="Battleground Coffer" horizontalAlignment="CENTER" verticalAlignment="BOTTOM">
                            <Dimensions x="175" y="24"/>
                            <Anchor point="TOPLEFT" relativeTo="$(parent)HeaderName" relativePoint="TOPRIGHT" offsetX="0" offsetY="0"/>
                        </Label>

                        <Label name="$(parent)HeaderAllianceTier" font="$(ANTIQUE_FONT)|16" wrapMode="ELLIPSIS" text="Alliance Tier" horizontalAlignment="CENTER" verticalAlignment="BOTTOM">
                            <Dimensions x="135" y="24"/>
                            <Anchor point="TOPLEFT" relativeTo="$(parent)HeaderBGCoffer" relativePoint="TOPRIGHT" offsetX="0" offsetY="0"/>
                        </Label>
                    </Controls>
                </Control>

                <Control name="$(parent)ListHolder">
                    <Anchor point="TOPLEFT" relativeTo="$(parent)" relativePoint="TOPLEFT" offsetX="0" offsetY="66" />
                    <Anchor point="BOTTOMRIGHT" relativeTo="$(parent)" relativePoint="BOTTOMRIGHT" offsetX="0" offsetY="0" />

                    <Controls>
                        <Control name="BattlegroundCoffersRow_Total">
                            <Anchor point="BOTTOMLEFT" relativeTo="$(parent)" relativePoint="BOTTOMLEFT" offsetX="0" offsetY="-4" />
                            <Anchor point="BOTTOMRIGHT" relativeTo="$(parent)" relativePoint="BOTTOMRIGHT" offsetX="0" offsetY="-4" />
                            <Dimensions x="480" y="24" />
                            <Controls>

                                <Label name="$(parent)RotW" font="$(ANTIQUE_FONT)|16" wrapMode="ELLIPSIS" horizontalAlignment="CENTER" verticalAlignment="CENTER">
                                    <Dimensions x="210" y="28" />
                                    <Anchor point="TOPLEFT" relativeTo="$(parent)" relativePoint="TOPLEFT" offsetX="0" offsetY="-2"/>
                                </Label>

                                <Button name="$(parent)Pages" font="ZoFontGameMedium" wrapMode="ELLIPSIS" horizontalAlignment="CENTER" verticalAlignment="CENTER" inherits="ZO_ButtonBehaviorClickSound">
                                    <Dimensions x="175" y="28" />
                                    <Anchor point="TOPLEFT" relativeTo="$(parent)" relativePoint="TOPLEFT" offsetX="210" offsetY="0"/>
                                    <OnClicked>BattlegroundCoffers.openStylesWindow()</OnClicked>
                                    <Textures
                                            normal="EsoUI/Art/Buttons/ESO_buttonLarge_normal.dds"
                                            pressed="EsoUI/Art/Buttons/ESO_buttonlLarge_mouseDown.dds"
                                            mouseOver="EsoUI/Art/Buttons/ESO_buttonLarge_mouseOver.dds"
                                            disabled="EsoUI/Art/Buttons/ESO_buttonLarge_disabled.dds"
                                    />
                                </Button>

                                <Label name="$(parent)Transmutes" font="ZoFontGameMedium" wrapMode="ELLIPSIS" horizontalAlignment="CENTER" verticalAlignment="CENTER">
                                    <Dimensions x="135" y="28" />
                                    <Anchor point="TOPLEFT" relativeTo="$(parent)Pages" relativePoint="TOPRIGHT" offsetX="0" offsetY="0"/>
                                </Label>
                            </Controls>
                        </Control>
                    </Controls>

                </Control>
            </Controls>
        </TopLevelControl>


        <Control name="BattlegroundCoffersTimerTemplate" virtual="true">
            <Dimensions x="480" y="24" />

            <Controls>
                <Texture name="$(parent)Bg" textureFile="EsoUI/Art/Miscellaneous/listItem_backdrop.dds" alpha="0.3">
                    <AnchorFill />
                    <TextureCoords left="0" right="1" top="0" bottom=".8125" />
                </Texture>

                <Label name="$(parent)Name" font="ZoFontGameMedium" wrapMode="ELLIPSIS" horizontalAlignment="CENTER" verticalAlignment="CENTER">
                    <Dimensions x="210" y="24" />
                    <Anchor point="TOPLEFT" relativeTo="$(parent)" relativePoint="TOPLEFT" offsetX="0" offsetY="0"/>
                </Label>

                <Label name="$(parent)BGCoffer" font="ZoFontGameMedium" wrapMode="ELLIPSIS" horizontalAlignment="CENTER" verticalAlignment="CENTER">
                    <Dimensions x="175" y="24" />
                    <Anchor point="TOPLEFT" relativeTo="$(parent)Name" relativePoint="TOPRIGHT" offsetX="0" offsetY="0"/>
                </Label>

                <Label name="$(parent)AllianceTier" font="ZoFontGameMedium" wrapMode="ELLIPSIS" horizontalAlignment="LEFT" verticalAlignment="CENTER">
                    <Dimensions x="135" y="24" />
                    <Anchor point="TOPLEFT" relativeTo="$(parent)BGCoffer" relativePoint="TOPRIGHT" offsetX="58" offsetY="0"/>
                </Label>

            </Controls>

        </Control>












        <TopLevelControl name="BattlegroundCoffers_Style_Window" mouseEnabled="true" movable="true" hidden="true">
            <Dimensions x="770" y="661" />
            <Controls>
                <Backdrop name="BattlegroundCoffers_Style_BG" centerColor="000000" edgeColor="202020">
                    <Dimensions x="770" y="661"/>
                    <AnchorFill/>
                    <Edge edgeSize="1"/>
                </Backdrop>
                <Backdrop name="BattlegroundCoffers_Style" centerColor="000000" edgeColor="000000">
                    <Anchor point="CENTER" relativeTo="BattlegroundCoffers_Style_BG" relativePoint="CENTER"/>
                    <Dimensions x="750" y="641"/>
                    <Controls>
                        <Backdrop name="$(parent)TopSection" centerColor="101010" edgeColor="202020">
                            <Anchor point="3" relativePoint="3" relativeTo="BattlegroundCoffers_Style"/>
                            <Dimensions x="750" y="40"/>
                            <Edge edgeSize="1"/>
                        </Backdrop>
                        <Label name="$(parent)Header" font="ZoFontGame" color="E9C62A" text="Battleground Emotes &amp; Style Pages">
                            <Anchor point="2" relativePoint="2" relativeTo="$(parent)TopSection" offsetX="10"/>
                        </Label>
                        <Label name="$(parent)HeaderInfo" font="ZoFontGame" color="E9C62A">
                            <Anchor point="TOPLEFT" relativeTo="$(parent)Header" relativePoint="TOPRIGHT" offsetX="20"/>
                        </Label>
                        <Button name="$(parent)CloseButton" clickSound="Click">
                            <Anchor point="8" relativePoint="8" relativeTo="$(parent)TopSection" offsetX="-5"/>
                            <Dimensions y="22" x="22"/>
                            <Textures normal="esoui/art/buttons/decline_up.dds" pressed="esoui/art/buttons/decline_down.dds" mouseOver="esoui/art/buttons/decline_over.dds"/>
                            <OnClicked>BattlegroundCoffers.closeStylesWindow()</OnClicked>
                        </Button>
                        <Backdrop name="$(parent)Panel" tier="1" centerColor="101010" edgeColor="202020" inherits="ZO_ScrollContainerBase">
                            <Anchor point="1" relativePoint="4" relativeTo="$(parent)TopSection" offsetY="1"/>
                            <Dimensions x="750" y="600"/>
                            <Edge edgeSize="1"/>
                            <OnInitialized>ZO_Scroll_Initialize(self)</OnInitialized>
                            <Controls>
                                <Control name="$(parent)ScrollChild" resizeToFitDescendents="true">
                                    <OnInitialized>self:SetParent(self:GetParent():GetNamedChild("Scroll"));self:SetAnchor(3,nil,3,0,0)</OnInitialized>
                                    <Controls>
                                        <Control name="$(parent)Styles" hidden="false">
                                            <Anchor point="3" relativePoint="3" relativeTo="$(parent)"/>
                                        </Control>
                                    </Controls>
                                </Control>
                            </Controls>
                        </Backdrop>
                    </Controls>
                </Backdrop>
            </Controls>
        </TopLevelControl>
        
        
        
        
        
        
    </Controls>
</GuiXml>