				<Anchor point="TOPRIGHT" relativeTo="$(parent)Header" relativePoint="BOTTOMRIGHT" offsetX="30" offsetY="3"/>
			</Texture>
			<Label name="$(parent)Left" font="TimFontTbarT2" text="" verticalAlignment="CENTER">
				<Anchor point="TOPLEFT" relativeTo="$(parent)Header" relativePoint="BOTTOMLEFT" offsetX="0" offsetY="10"/>
			</Label>
			<Label name="$(parent)Middle" font="TimFontTbarT2" text="" horizontalAlignment="LEFT" verticalAlignment="CENTER">
				<Anchor point="TOPLEFT" relativeTo="$(parent)Left" relativePoint="TOPRIGHT" offsetX="10" offsetY="0"/>
			</Label>
			<Label name="$(parent)Right" font="TimFontTbarT2" text="" horizontalAlignment="LEFT" verticalAlignment="CENTER">
