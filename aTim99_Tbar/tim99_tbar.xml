<GuiXml> 
	<!-- New Font definition -->
	<!-- 
	"BOLD_FONT", "CHAT_FONT", "MEDIUM_FONT"
	"outline", "thick-outline", "shadow", "soft-shadow-thick", "soft-shadow-thin"
	-->
	<!-- <Font name="TimFontTbarM"  font="$(BOLD_FONT)|16|soft-shadow-thin"/> -->
	<!-- <Font name="TimFontTbarM"  font="$(MEDIUM_FONT)|16|soft-shadow-thin"/> -->
	<Font name="TimFontTbarB"  font="$(BOLD_FONT)|16|soft-shadow-thin"/>
	<Font name="TimFontTbarT"  font="$(MEDIUM_FONT)|18|soft-shadow-thin"/>
	<Font name="TimFontTbarT2" font="$(MEDIUM_FONT)|17|soft-shadow-thin"/>
	
	<Font name="TimFontTbarM"  font="$(BOLD_FONT)|16|soft-shadow-thin"/>

<Controls> 
	<!-- Tooltip Writs-->
	<TopLevelControl name="TimTbarTooltipWrits" mouseEnabled="true" movable="false" clampedToScreen="true" layer="3" hidden="true">
		<!--<Dimensions x="410" y="300"/>-->
		<Anchor point="TOPLEFT"/>
		<Controls>
			<Backdrop name="$(parent)BG" alpha="1" edge="0" inherits="ZO_DefaultBackdrop"/>
			<Label name="$(parent)Header" font="ZoFontHeader" color="999999" text="Crafting Writs" verticalAlignment="CENTER" horizontalAlignment="CENTER">
				<Anchor point="TOPLEFT" relativeTo="$(parent)" relativePoint="TOPLEFT" offsetX="0" offsetY="0"/>
				<Anchor point="TOPRIGHT" relativeTo="$(parent)" relativePoint="TOPRIGHT" offsetX="0" offsetY="0"/>
			</Label>
			<Texture name="$(parent)Divider" textureFile="EsoUI/Art/Miscellaneous/horizontalDivider.dds">
				<Dimensions y="4"/>
				<Anchor point="TOPLEFT" relativeTo="$(parent)Header" relativePoint="BOTTOMLEFT" offsetX="-30" offsetY="3"/>
				<Anchor point="TOPRIGHT" relativeTo="$(parent)Header" relativePoint="BOTTOMRIGHT" offsetX="30" offsetY="3"/>
			</Texture>
			<Label name="$(parent)Left" font="TimFontTbarT2" text="" verticalAlignment="CENTER">
				<Anchor point="TOPLEFT" relativeTo="$(parent)Header" relativePoint="BOTTOMLEFT" offsetX="0" offsetY="9"/>
			</Label>
			<Label name="$(parent)Right" font="TimFontTbarT2" text="" horizontalAlignment="LEFT" verticalAlignment="CENTER">
				<Anchor point="TOPRIGHT" relativeTo="$(parent)Header" relativePoint="BOTTOMRIGHT" offsetX="-10" offsetY="10"/>
			</Label>
		</Controls>
	</TopLevelControl>
	<!-- Tooltip Stiller-->
	<TopLevelControl name="TimTbarTooltipStill" mouseEnabled="true" movable="false" clampedToScreen="true" layer="3" hidden="true">
		<!--<Dimensions x="410" y="300"/>-->
		<Anchor point="TOPLEFT"/>
		<Controls>
			<Backdrop name="$(parent)BG" alpha="1" edge="0" inherits="ZO_DefaultBackdrop"/>
			<Label name="$(parent)Header" font="ZoFontHeader" color="999999" text="DB-Supplier" verticalAlignment="CENTER" horizontalAlignment="CENTER">
				<Anchor point="TOPLEFT" relativeTo="$(parent)" relativePoint="TOPLEFT" offsetX="0" offsetY="0"/>
				<Anchor point="TOPRIGHT" relativeTo="$(parent)" relativePoint="TOPRIGHT" offsetX="0" offsetY="0"/>
			</Label>
			<Texture name="$(parent)Divider" textureFile="EsoUI/Art/Miscellaneous/horizontalDivider.dds">
				<Dimensions y="4"/>
				<Anchor point="TOPLEFT" relativeTo="$(parent)Header" relativePoint="BOTTOMLEFT" offsetX="-30" offsetY="3"/>
				<Anchor point="TOPRIGHT" relativeTo="$(parent)Header" relativePoint="BOTTOMRIGHT" offsetX="30" offsetY="3"/>
			</Texture>
			<Label name="$(parent)Left" font="TimFontTbarT2" text="" verticalAlignment="CENTER">
				<Anchor point="TOPLEFT" relativeTo="$(parent)Header" relativePoint="BOTTOMLEFT" offsetX="0" offsetY="10"/>
			</Label>
			<Label name="$(parent)Right" font="TimFontTbarT2" text="" horizontalAlignment="LEFT" verticalAlignment="CENTER">
				<Anchor point="TOPRIGHT" relativeTo="$(parent)Header" relativePoint="BOTTOMRIGHT" offsetX="-10" offsetY="10"/>
			</Label>
		</Controls>
	</TopLevelControl>
	<!-- Tooltip Mount-->
	<TopLevelControl name="TimTbarTooltipMount" mouseEnabled="true" movable="false" clampedToScreen="true" layer="3" hidden="true">
		<!--<Dimensions x="410" y="300"/>-->
		<Anchor point="TOPLEFT"/>
		<Controls>
			<Backdrop name="$(parent)BG" alpha="1" edge="0" inherits="ZO_DefaultBackdrop"/>
			<Label name="$(parent)Header" font="ZoFontHeader" color="999999" text="Mount-Feeding" verticalAlignment="CENTER" horizontalAlignment="CENTER">
				<Anchor point="TOPLEFT" relativeTo="$(parent)" relativePoint="TOPLEFT" offsetX="0" offsetY="0"/>
				<Anchor point="TOPRIGHT" relativeTo="$(parent)" relativePoint="TOPRIGHT" offsetX="0" offsetY="0"/>
			</Label>
			<Texture name="$(parent)Divider" textureFile="EsoUI/Art/Miscellaneous/horizontalDivider.dds">
				<Dimensions y="4"/>
				<Anchor point="TOPLEFT" relativeTo="$(parent)Header" relativePoint="BOTTOMLEFT" offsetX="-30" offsetY="3"/>
				<Anchor point="TOPRIGHT" relativeTo="$(parent)Header" relativePoint="BOTTOMRIGHT" offsetX="30" offsetY="3"/>
			</Texture>
			<Label name="$(parent)Left" font="TimFontTbarT2" text="" verticalAlignment="CENTER">
				<Anchor point="TOPLEFT" relativeTo="$(parent)Header" relativePoint="BOTTOMLEFT" offsetX="0" offsetY="10"/>
			</Label>
			<Label name="$(parent)Right" font="TimFontTbarT2" text="" horizontalAlignment="LEFT" verticalAlignment="CENTER">
				<Anchor point="TOPRIGHT" relativeTo="$(parent)Header" relativePoint="BOTTOMRIGHT" offsetX="-10" offsetY="10"/>
			</Label>
		</Controls>
	</TopLevelControl>
	<!-- Tooltip LoginRewards-->
	<!--
	<TopLevelControl name="TimTbarTooltipLogin" mouseEnabled="true" movable="false" clampedToScreen="true" layer="3" hidden="true">
